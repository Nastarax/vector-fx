.env
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
# Cache files: ignore most, but allow committing retail sentiment so the live
# CI run can fall back to the last successful local fetch if Myfxbook blocks
# the GitHub Actions IP.
data/cache/*.json
data/cache/*.csv
data/cache/*.pkl
!data/cache/myfxbook_outlook.json
# Forexbenchmark.com per-pair retail positioning. Same fallback model:
# committed so CI has data when the live fetch fails.
!data/cache/forexbenchmark_outlook.json
# Same reason for FF history: local scraping accumulates over time and we
# want CI to use the accumulated data (FF blocks GitHub Actions IPs).
!data/cache/ff_history.json
# TE history accumulates from manual sweeps; commit so CI inherits the data
!data/cache/te_history.json
# Same reason for Investing.com PMI cache: Cloudflare blocks GitHub Actions IPs
# completely. Refresh runs locally and the JSON is committed.
!data/cache/investing_pmi.json
# Services PMI cache (6 Investing pages + 2 TE pages). Same local-refresh model.
!data/cache/spmi.json
# CPI YoY cache (Investing.com, all 8 currencies). Local refresh, GH Actions reads.
!data/cache/investing_cpi.json
# PPI YoY cache (Investing.com, NZD only; other 7 use TE history). Local refresh.
!data/cache/investing_ppi.json
# FF rates outlook (next-meeting consensus forecast per currency). Refreshed
# every main.py run, cached as fallback.
!data/cache/ff_rates_outlook.json
# TE rates outlook (current rate + next-meeting TEForecast per currency).
# Refreshed every main.py run.
!data/cache/te_rates_outlook.json
# AUD Monthly Household Spending Indicator cache (replaces TE retail sales
# for AUD only). ABS isn't bot-blocked so this gets refreshed every main.py
# run, but cache it for backtest mode.
!data/cache/abs_au_household.json
# US Consumer Confidence cache (Investing CB, id 48). Local refresh, GH Actions reads.
!data/cache/investing_consumer_conf.json
# US JOLTS cache (Investing, id 1057). Local refresh only.
!data/cache/investing_jolts.json
# US ADP cache (Investing, id 1). Local refresh only.
!data/cache/investing_adp.json
# CHF PPI cache (Myfxbook Swiss Producer & Import Prices). Local refresh only.
!data/cache/myfxbook_ppi.json
# CAD Retail Sales MoM cache (Investing, id 260). Local refresh only.
!data/cache/investing_retail_sales.json
# Tokyo Core CPI snapshot (JPY CPI source, rides along with CPI refresh).
!data/cache/tokyo_core_cpi.json
# Deep CPI history archive (Investing __NEXT_DATA__, all 8). Powers inflation chart.
!data/cache/cpi_investing_history.json
# Persistent CPI YoY archive (merged from all sources). Never drops old points.
!data/cache/cpi_history_archive.json
# CPI forecast archive (consensus estimates from Investing). Powers CPI indicator chart.
!data/cache/cpi_forecast_archive.json
# US Core CPI + Core PPI (Investing, gold inflation scoring). Local refresh only.
!data/cache/investing_core.json
# Daily score history for scorecard "Score over time" chart.
!data/cache/score_history.json
scripts/.last_refresh
# Local refresh log: written every run, so tracking it would dirty the working
# tree and break the scheduler's rebase. Keep it local-only.
scripts/daily_refresh.log

# Claude Code harness artifacts
.claude/
# Pair setup states (WATCH/EXT/MID) from the previous run; the WATCH-flip
# alert diff baseline. Committed by the workflow so it survives between runs.
!data/cache/setup_state.json
# Release calendar: next-release date per cell. Drives Phase 2 due-gating and
# self-advances as each source is fetched; committed so it persists between runs.
!data/cache/release_calendar.json
