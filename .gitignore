.env
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
# Cache files: ignore most, but allow committing retail sentiment so the live
# CI run can fall back to the last successful local fetch if Myfxbook blocks
# the GitHub Actions IP.
data/cache/*.json
data/cache/*.csv
data/cache/*.pkl
!data/cache/myfxbook_outlook.json
# Forexbenchmark.com per-pair retail positioning. Same fallback model:
# committed so CI has data when the live fetch fails.
!data/cache/forexbenchmark_outlook.json
# Same reason for FF history: local scraping accumulates over time and we
# want CI to use the accumulated data (FF blocks GitHub Actions IPs).
!data/cache/ff_history.json
# TE history accumulates from manual sweeps; commit so CI inherits the data
!data/cache/te_history.json
# Same reason for Investing.com PMI cache: Cloudflare blocks GitHub Actions IPs
# completely. Refresh runs locally and the JSON is committed.
!data/cache/investing_pmi.json
# Services PMI cache (6 Investing pages + 2 TE pages). Same local-refresh model.
!data/cache/spmi.json
# CPI YoY cache (Investing.com, all 8 currencies). Local refresh, GH Actions reads.
!data/cache/investing_cpi.json
# PPI YoY cache (Investing.com, NZD only; other 7 use TE history). Local refresh.
!data/cache/investing_ppi.json
# FF rates outlook (next-meeting consensus forecast per currency). Refreshed
# every main.py run, cached as fallback.
!data/cache/ff_rates_outlook.json
# TE rates outlook (current rate + next-meeting TEForecast per currency).
# Refreshed every main.py run.
!data/cache/te_rates_outlook.json
# AUD Monthly Household Spending Indicator cache (replaces TE retail sales
# for AUD only). ABS isn't bot-blocked so this gets refreshed every main.py
# run, but cache it for backtest mode.
!data/cache/abs_au_household.json
